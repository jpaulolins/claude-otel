{
  "mcpServers": {
    "claude-otel": {
      "url": "http://localhost:8081/mcp",
      "headers": {
        "Authorization": "Bearer CHANGE_ME"
      }
    }
  },
  "telemetry": {
    "enabled": true,
    "traces": true,
    "target": "local",
    "otlpEndpoint": "http://localhost:4318",
    "otlpProtocol": "http",
    "useCollector": true,
    "logPrompts": false
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "cotel hook", "timeout": 5000 }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "cotel hook", "timeout": 5000 }
        ]
      }
    ]
  }
}
