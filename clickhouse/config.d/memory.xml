<clickhouse>
    <listen_host>0.0.0.0</listen_host>

    <!-- Raise server cap above the ~680 MiB RSS ClickHouse reaches after seeding.
         The original 700 MiB cap left zero query headroom (RSS > cap → error 241).
         1 GiB gives ~320 MiB for queries on top of the ~680 MiB warm-cache base.
         Smaller caches reduce the warm-cache baseline so the cap is more effective. -->
    <max_server_memory_usage>1073741824</max_server_memory_usage>
    <mark_cache_size>33554432</mark_cache_size>
    <uncompressed_cache_size>33554432</uncompressed_cache_size>

    <profiles>
        <default>
            <max_memory_usage>400000000</max_memory_usage>
            <max_bytes_before_external_group_by>200000000</max_bytes_before_external_group_by>
            <max_bytes_before_external_sort>200000000</max_bytes_before_external_sort>
        </default>
    </profiles>
</clickhouse>
